agent my-agent {
  default deny

  rules {
    deny! shell/run
      when cmd matches "rm -rf|DROP TABLE|terraform destroy|shutdown|reboot"
      reason: "destructive command blocked"

    deny! fs/write
      when path matches "/etc|/usr|/bin|/sbin|/boot"
      reason: "system path write blocked"

    defer payment/transfer when amount > 500
      notify: "finance-team"

    permit api/*
    permit search/*
    permit read_*
  }
}
